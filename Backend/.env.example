# Servidor
PORT=3001
NODE_ENV=dev

# Banco de dados (PostgreSQL)
DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco

# JWT
JWT_SECRET=sua_chave_secreta_minimo_10_caracteres

# URL base da API (usada para gerar links de teste)
APP_URL=http://localhost:3001/api

# OpenAI (geração de JD e match de candidatos)
OPENAI_API_KEY=sk-...

# Resend (envio de emails)
RESEND_API_KEY=re_...
EMAIL_FROM=onboarding@resend.dev
